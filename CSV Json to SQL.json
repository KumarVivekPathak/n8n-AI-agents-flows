    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Extract JSON + filter required statuses\nconst filteredData = items\n  .map(i => i.json)\n  .filter(item =>\n    item.status === \"captured\" ||\n    item.status === \"created\" ||\n    item.status === \"refunded\"\n  );\n\n// Return as ONE single item containing filtered array\nreturn [\n  {\n    json: {\n      allData: filteredData\n    }\n  }\n];"
      },
