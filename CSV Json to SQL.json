    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction formatDate(input) {\n  if (!input) return null;\n\n  const parts = input.split(\" \");\n  if (!parts[0]) return null;\n\n  const d = parts[0].split(\"/\");\n  if (d.length !== 3) return null;\n\n  const day = d[0].padStart(2, \"0\");\n  const month = d[1].padStart(2, \"0\");\n  const year = d[2];\n  const time = parts[1] || \"00:00:00\";\n\n  return `${year}-${month}-${day} ${time}`;\n}\n\nconst output = [];\n\nfor (const i of items) {\n  const item = i.json;\n\n  // Filter status\n  if (\n    item.status !== \"captured\" &&\n    item.status !== \"created\" &&\n    item.status !== \"refunded\"\n  ) continue;\n\n  let notes = {};\n  try {\n    notes = item.notes ? JSON.parse(item.notes) : {};\n  } catch (e) {\n    notes = {};\n  }\n\n  const name =\n    notes.name ||\n    notes.full_name ||\n    (notes.first_name && notes.last_name\n      ? notes.first_name + \" \" + notes.last_name\n      : null);\n\n  const course_name =\n    notes.course ||\n    notes.course_name ||\n    notes.report ||\n    notes.reports ||\n    notes.report_name ||\n    null;\n\n  output.push({\n    json: {\n      order_id: item.order_id,\n      created_at: formatDate(item.created_at),\n      name,\n      email: item.email,\n      course_name,\n      amount: Number(item.amount) || 0,\n      contact: item.contact,\n      phone: notes.phone || null,\n      city: notes.city || null,\n      dob: notes.dob || null,\n      payment_id: item.id,\n      status: item.status,\n      currency: item.currency,\n      auth_code: item.Auth_code,\n      international: Number(item.international) || 0,\n      method: item.method,\n      amount_refunded: Number(item.amount_refunded) || 0,\n      vpa: item.vpa,\n      fee: Number(item.fee) || 0,\n      tax: Number(item.tax) || 0,\n      payments_rrn: item.Payments_RRN,\n      flow: item.flow\n    }\n  });\n}\n\nreturn output;"
      },
