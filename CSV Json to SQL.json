    {
      "parameters": {
        "jsCode": "function formatDate(input) {\n  if (!input) return null;\n\n  const parts = input.split(\" \");\n  if (!parts[0]) return null;\n\n  const d = parts[0].split(\"/\");\n  if (d.length !== 3) return null;\n\n  const day = d[0].padStart(2, \"0\");\n  const month = d[1].padStart(2, \"0\");\n  const year = d[2];\n  const time = parts[1] || \"00:00:00\";\n\n  return `${year}-${month}-${day} ${time}`;\n}\n\nconst output = [];\n\nfor (const item of items) {\n\n  let notes = {};\n  try {\n    notes = item.json.notes ? JSON.parse(item.json.notes) : {};\n  } catch (e) {\n    notes = {};\n  }\n\n  const name =\n    notes.name ||\n    notes.full_name ||\n    (notes.first_name && notes.last_name\n      ? notes.first_name + \" \" + notes.last_name\n      : null);\n\n  const course_name =\n    notes.course ||\n    notes.course_name ||\n    notes.report ||\n    notes.reports ||\n    notes.report_name ||\n    null;\n\n  output.push({\n    json: {\n      order_id: item.json.order_id,\n      created_at: formatDate(item.json.created_at),\n      name: name,\n      email: item.json.email,\n      course_name: course_name,\n      amount: Number(item.json.amount) || 0,\n      contact: item.json.contact,\n      phone: notes.phone || null,\n      city: notes.city || null,\n      dob: notes.dob || null,\n      payment_id: item.json.id,\n      status: item.json.status,\n      currency: item.json.currency,\n      auth_code: item.json.Auth_code,\n      international: Number(item.json.international) || 0,\n      method: item.json.method,\n      amount_refunded: Number(item.json.amount_refunded) || 0,\n      vpa: item.json.vpa,\n      fee: Number(item.json.fee) || 0,\n      tax: Number(item.json.tax) || 0,\n      payments_rrn: item.json.Payments_RRN,\n      flow: item.json.flow\n    }\n  });\n}\n\nreturn output;"
      },
