    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst chunkSize = 1000; // adjust if needed\nconst output = [];\n\n// Escape helper (important for SQL safety)\nfunction escapeValue(value) {\n  if (value === null || value === undefined) return \"NULL\";\n  return `'${String(value).replace(/'/g, \"''\")}'`;\n}\n\nfor (let i = 0; i < items.length; i += chunkSize) {\n\n  const chunk = items.slice(i, i + chunkSize);\n\n  const values = chunk.map(i => {\n    const d = i.json;\n\n    return `(\n      ${escapeValue(d.order_id)},\n      ${escapeValue(d.created_at)},\n      ${escapeValue(d.name)},\n      ${escapeValue(d.email)},\n      ${escapeValue(d.course_name)},\n      ${Number(d.amount) || 0},\n      ${escapeValue(d.contact)},\n      ${escapeValue(d.phone)},\n      ${escapeValue(d.city)},\n      ${escapeValue(d.dob)},\n      ${escapeValue(d.payment_id)},\n      ${escapeValue(d.status)},\n      ${escapeValue(d.currency)},\n      ${escapeValue(d.auth_code)},\n      ${Number(d.international) || 0},\n      ${escapeValue(d.method)},\n      ${Number(d.amount_refunded) || 0},\n      ${escapeValue(d.vpa)},\n      ${Number(d.fee) || 0},\n      ${Number(d.tax) || 0},\n      ${escapeValue(d.payments_rrn)},\n      ${escapeValue(d.flow)}\n    )`;\n  }).join(\",\");\n\n  const query = `\n    INSERT INTO payment_table (\n      order_id,\n      created_at,\n      name,\n      email,\n      course_name,\n      amount,\n      contact,\n      phone,\n      city,\n      dob,\n      payment_id,\n      status,\n      currency,\n      auth_code,\n      international,\n      method,\n      amount_refunded,\n      vpa,\n      fee,\n      tax,\n      payments_rrn,\n      flow\n    )\n    VALUES ${values}\n    ON DUPLICATE KEY UPDATE\n      status = VALUES(status),\n      amount_refunded = VALUES(amount_refunded),\n      fee = VALUES(fee),\n      tax = VALUES(tax);\n  `;\n\n  output.push({ json: { query } });\n}\n\nreturn output;"
      },
